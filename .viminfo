"2	LINE	0
	import json
	import os
	from datetime import datetime
	
	class FoodDeliveryApp:
	    def __init__(self):
	        self.menu = {
	            "1": {"name": "Margherita Pizza", "price": 12.99, "category": "Pizza"},
	            "2": {"name": "Cheeseburger", "price": 8.99, "category": "Burger"},
	            "3": {"name": "Chicken Wings", "price": 10.99, "category": "Appetizer"},
	            "4": {"name": "Caesar Salad", "price": 7.99, "category": "Salad"},
	            "5": {"name": "Pasta Alfredo", "price": 13.99, "category": "Pasta"},
	            "6": {"name": "Soda", "price": 2.49, "category": "Beverage"},
	            "7": {"name": "French Fries", "price": 3.99, "category": "Sides"},
	            "8": {"name": "Ice Cream", "price": 4.99, "category": "Dessert"}
	        }
	        self.cart = {}
	        self.orders = []
	        self.current_order_id = 1
	        self.load_data()
	    
	    def load_data(self):
	        """Load previous orders from file if exists"""
	        if os.path.exists("orders.json"):
	            try:
	                with open("orders.json", "r") as f:
	                    data = json.load(f)
	                    self.orders = data.get("orders", [])
	                    self.current_order_id = data.get("next_order_id", 1)
	            except:
	                pass
	    
	    def save_data(self):
	        """Save orders to file"""
	        data = {
	            "orders": self.orders,
	            "next_order_id": self.current_order_id
	        }
	        with open("orders.json", "w") as f:
	            json.dump(data, f, indent=2)
	    
	    def display_menu(self):
	        """Display all menu items"""
	        print("\n" + "="*50)
	        print("🍕 OUR MENU 🍔".center(50))
	        print("="*50)
	        for item_id, item in self.menu.items():
	            print(f"{item_id}. {item['name']:<20} ${item['price']:.2f}  ({item['category']})")
	        print("="*50)
	    
